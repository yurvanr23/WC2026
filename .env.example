# Application
APP_NAME=WC26 Intelligence Platform
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://wc26:wc26pass@localhost:5432/wc26_db

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ML Configuration
MODEL_VERSION=v1.0.0
MODEL_PATH=../ml/models
SHAP_ENABLED=true
FEATURE_CACHE_ENABLED=true

# Simulation
MONTE_CARLO_ITERATIONS=10000
SIMULATION_CACHE_TTL=3600

# Scoring System
POINTS_CORRECT_RESULT=3
POINTS_EXACT_SCORE=5
POINTS_CORRECT_WINNER=2
POINTS_UPSET_BONUS=2

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# MLflow (optional)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ENABLED=false
